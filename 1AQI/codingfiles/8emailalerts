# ====== EMAIL ALERT FUNCTION ======
def send_email_alert(aqi_value, category):
    subject = f"⚠️ PolluCast Air Quality Alert – {category}"

    body = f"""
Hello,

This is an automated air quality alert from the PolluCast System.

📍 Predicted AQI: {aqi_value:.2f}
📊 AQI Category: {category}

Health Advisory:
"""

    if category in ["Good", "Satisfactory"]:
        body += """
Air quality is acceptable.
No significant health risks. Enjoy your day 🌿
"""
    elif category == "Moderate":
        body += """
Sensitive individuals may experience minor discomfort.
Limit prolonged outdoor activities.
"""
    elif category == "Poor":
        body += """
Breathing discomfort possible for people with lung or heart conditions.
Avoid outdoor exertion.
"""
    elif category == "Very Poor":
        body += """
High health risk for all individuals.
Stay indoors and wear mask if going outside.
"""
    else:  # Severe
        body += """
Severe health risk for everyone.
Avoid outdoor exposure completely.
"""

    body += """

Stay safe,
PolluCast – Live Air Pollution Predictor 🌍
"""

    # ====== EMAIL SETUP ======
    msg = MIMEMultipart()
    msg["From"] = SENDER_EMAIL
    msg["To"] = ", ".join(RECEIVER_EMAILS)   # multiple users
    msg["Subject"] = subject
    msg.attach(MIMEText(body, "plain"))

    try:
        server = smtplib.SMTP("smtp.gmail.com", 587)
        server.starttls()
        server.login(SENDER_EMAIL, APP_PASSWORD)

        # send to all users
        server.sendmail(SENDER_EMAIL, RECEIVER_EMAILS, msg.as_string())
        server.quit()

        print("✅ PolluCast alert sent to all users successfully!")

    except Exception as e:
        print("❌ Email sending failed:", e)


